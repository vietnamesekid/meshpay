{
  "name": "@meshpay/cli",
  "version": "0.3.1",
  "description": "CLI dev tools — npx meshpay init",
  "type": "module",
  "bin": {
    "meshpay": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@meshpay/core": "workspace:*",
    "@meshpay/protocols": "workspace:*",
    "@meshpay/wallet": "workspace:*",
    "picocolors": "^1.1.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@meshpay/tsconfig": "workspace:^"
  }
}
