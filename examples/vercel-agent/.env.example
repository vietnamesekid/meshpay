# Copy to .env.local and fill in your values

# Required: OpenAI API key for the LLM
OPENAI_API_KEY=sk-...

# Optional: Coinbase CDP API key for x402 settlement
# Without this you get 1K free tx/month (unauthenticated)
COINBASE_CDP_API_KEY=

# Optional: AP2 signing key — random 32+ byte string
# Defaults to 'meshpay-dev-key' (insecure, dev only)
MESHPAY_AP2_KEY=

# Optional: ephemeral wallet private key
# If omitted, a fresh key is generated each run (balance = 0, fine for mock)
WALLET_PRIVATE_KEY=

# Mock x402 server URL (used when MOCK_MODE=true)
MOCK_SERVER_URL=http://localhost:4402
